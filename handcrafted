def categoriser_vin(note):
    if note <= 4: return 'Médiocre'
    elif note <= 6: return 'Standard'
    else: return 'Exceptionnel'

df['Catégorie'] = df['quality'].apply(categoriser_vin)
palette_vin = {'Médiocre': '#d62728', 'Standard': '#cccccc', 'Exceptionnel': '#2ca02c'}

# --- CRÉATION DES VARIABLES ---
df['balance_sulfates_acidity'] = df['sulphates'] - df['volatile acidity']
df['alcohol_minus_volatile'] = df['alcohol'] - df['volatile acidity']
